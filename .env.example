# ============================================
# Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ============================================

# Google Gemini (trabalho bruto / geração em massa)
GEMINI_API_KEY=
GEMINI_PROJECT_ID=projects/145801178452

# Anthropic Claude (revisão crítica / MAX)
ANTHROPIC_API_KEY=

# Telegram Bot (interface de comando)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_AUTHORIZED=

# Supabase (memória de longo prazo)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ElevenLabs (narração de áudio com IA)
ELEVENLABS_API_KEY=

# Deploy (URL pública para webhook do Telegram)
RENDER_URL=

# Identidade da marca (opcional — substitui nome do sistema nas mensagens do bot)
BRAND_NAME=

# NexusPDF — API de geração de PDFs (integração externa)
# Defina uma chave forte. Sem ela, a API fica aberta (só use assim em dev local).
NEXUS_API_KEY=

# Puppeteer — caminho do Chrome no servidor (Railway/VPS)
# Deixe vazio para usar o Chromium local instalado pelo npm
PUPPETEER_EXECUTABLE_PATH=
