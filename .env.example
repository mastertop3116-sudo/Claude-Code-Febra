# ============================================
# NEXUS DIGITAL HOLDING — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ============================================

# Google Gemini (trabalho bruto / geração em massa)
GEMINI_API_KEY=sua_chave_aqui
GEMINI_PROJECT_ID=projects/145801178452

# Anthropic Claude (revisão crítica / MAX)
ANTHROPIC_API_KEY=sua_chave_aqui

# Telegram Bot (interface de comando)
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Supabase (memória de longo prazo)
SUPABASE_URL=sua_url_aqui
SUPABASE_ANON_KEY=sua_chave_aqui

# Canva API (Departamento de Criativos)
CANVA_API_KEY=sua_chave_aqui
